  };

  const stats = [
    { label: 'Total Orders', value: '24', icon: '📦' },
    { label: 'Total Spent', value: '$1,850.75', icon: '💰' },
    { label: 'Reward Points', value: '1,250', icon: '⭐' },
    { label: 'Wishlist', value: '8', icon: '❤️' },
  ];

  return (
    <IonPage className="account-page">
      <IonHeader>
        <IonToolbar>
          <IonTitle>My Account</IonTitle>
        </IonToolbar>
      </IonHeader>

